@startuml
skinparam style strictuml
skinparam shadowing false
skinparam rectangle {
  BackgroundColor #F8F9FA
  BorderColor #2C3E50
}
skinparam package {
  BackgroundColor #FFFFFF
  BorderColor #34495E
}
skinparam database {
  BackgroundColor #FCF3CF
}
skinparam actorStyle awesome

title ImpulsaEdu — Use Case / Información de flujo

' =========================
' ACTORS
' =========================
actor "Donante" as Donor
actor "Escuela" as School
actor "Personal (staff)" as Staff
actor "Administrador (admin)" as Admin

' =========================
' PUBLIC DASHBOARD
' =========================
rectangle "Panel público (información - solo lectura)" as Public {

  package "Catálogo de escuelas" {
    component "Buscar / Filtrar\n(región, categoría)" as Filter
    component "Detalle de escuela" as SchoolView
    component "Barra de progreso\n(calculada por API)" as ProgressBar
  }

}

' =========================
' ADMIN SYSTEM
' =========================
rectangle "Sistema administrativo (NGO)" as System {

  package "Autenticación y RBAC" as Auth {
    component "Login (POST /auth/login)"
    component "Validación JWT"
    component "Control de roles\n(admin / staff)"
  }

  package "Gestión de escuelas" as SchoolMgmt {
    component "Crear / Actualizar / Archivar escuela"
    component "Validación: no duplicados (name+region)"
  }

  package "Gestión de donantes" as DonorMgmt {
    component "Crear / Actualizar donante"
    component "Historial de donaciones"
    component "Validación: no duplicados (name+region)"
  }

  package "Gestión de donaciones" as DonationMgmt {
    component "Crear registro de donación (POST /api/v1/donations)"
    component "Vincular donante ↔ escuela"
    component "Tipo: material / monetary"
    component "Modo de entrega (donor_to_school / donor_to_ngo / donor_to_pickup)"
    component "Registrar amount / estimated_value"
  }

  package "Motor de flujo (state machine)" as Workflow {
    component "States:\nregistered\napproved\nin_delivery\ndelivered\ncompleted\ncancelled"
    component "Validación de transiciones (API)"
  }

  package "Módulo de reportes" as Reports {
    component "Donations by school (admin)"
    component "Donations by donor (admin)"
    component "Pending deliveries"
    component "Completed donations"
  }

  database "PostgreSQL (impulsa)" as DB {
    component "users / refresh_tokens"
    component "schools / schools_needs"
    component "donors / contacts"
    component "donations / donation_items"
    component "audit_logs"
  }

}

' =========================
' EXTERNAL INTERACTIONS
' =========================

Donor --> Filter : Navega catálogo
Filter --> SchoolView
SchoolView --> ProgressBar

Donor --> Staff : Contacto (offline / form)
Escuela --> Staff : Solicita apoyo (offline / form)

' =========================
' AUTHENTICATION FLOW
' =========================

Staff --> Login
Admin --> Login

Login --> "Validación JWT"
"Validación JWT" --> "Control de roles\n(admin / staff)"

' =========================
' SCHOOL REGISTRATION FLOW
' =========================

Staff --> "Crear / Actualizar / Archivar escuela"
"Crear / Actualizar / Archivar escuela" --> "Validación: no duplicados (name+region)"
"Validación: no duplicados (name+region)" --> DB

' =========================
' DONOR REGISTRATION FLOW
' =========================

Staff --> "Crear / Actualizar donante"
"Crear / Actualizar donante" --> "Validación: no duplicados (name+region)"
"Validación: no duplicados (name+region)" --> DB

' =========================
' DONATION CREATION FLOW
' =========================

Staff --> "Crear registro de donación"
"Crear registro de donación" --> "Vincular donante ↔ escuela"
"Vincular donante ↔ escuela" --> DB

"Crear registro de donación" --> "Tipo: material / monetary"
"Tipo: material / monetary" --> "Registrar amount / estimated_value"

"Crear registro de donación" --> "Modo de entrega (donor_to_school / donor_to_ngo / donor_pickup)"
"Modo de entrega (donor_to_school / donor_to_ngo / donor_pickup)" --> DB

"Crear registro de donación" --> Workflow
Workflow --> DB

' =========================
' PROGRESS BAR LOGIC
' =========================

DB --> ProgressBar : confirmed_value / funding_goal (progress_pct)

' =========================
' REPORTING FLOW
' =========================

Staff --> Reports
Reports --> DB

@enduml
