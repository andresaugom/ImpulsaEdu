{
  "rulesets": [
    {
      "name": "Main Branch Protection",
      "description": "Protects the main branch with required reviews and restrictions",
      "target": "branch",
      "enforcement": "active",
      "bypass_actors": [],
      "conditions": {
        "ref_name": {
          "include": [
            "refs/heads/main"
          ],
          "exclude": []
        }
      },
      "rules": [
        {
          "type": "creation",
          "parameters": {
            "restriction": "all"
          }
        },
        {
          "type": "update",
          "parameters": {
            "update_allows_fetch_and_merge": false
          }
        },
        {
          "type": "deletion",
          "parameters": {
            "restriction": "all"
          }
        },
        {
          "type": "required_status_checks",
          "parameters": {
            "strict_required_status_checks_policy": false,
            "required_status_checks": []
          }
        },
        {
          "type": "required_reviews",
          "parameters": {
            "required_approving_review_count": 1,
            "require_code_owner_reviews": false,
            "require_last_push_approval": false,
            "dismiss_stale_reviews_on_push": false
          }
        },
        {
          "type": "pull_request",
          "parameters": {
            "dismiss_stale_reviews_on_new_push": false,
            "require_code_owner_review": false,
            "require_last_push_approval": false,
            "required_approving_review_count": 1,
            "required_review_thread_resolution": false
          }
        }
      ]
    },
    {
      "name": "Restrict Push to Main",
      "description": "No direct pushes to main - all changes must go through PRs",
      "target": "branch",
      "enforcement": "active",
      "bypass_actors": [
        {
          "actor_type": "Management",
          "actor_id": 1
        }
      ],
      "conditions": {
        "ref_name": {
          "include": [
            "refs/heads/main"
          ],
          "exclude": []
        }
      },
      "rules": [
        {
          "type": "restrict_pushes",
          "parameters": {
            "restricts_pushes": true,
            "push_allowances": [
              {
                "type": "RepositoryRole",
                "repository_role_database_id": null
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Feature Branch Protection",
      "description": "Prevents users from pushing to others' branches",
      "target": "branch",
      "enforcement": "active",
      "bypass_actors": [
        {
          "actor_type": "Management",
          "actor_id": 1
        }
      ],
      "conditions": {
        "ref_name": {
          "include": [
            "refs/heads/feature/*",
            "refs/heads/bugfix/*",
            "refs/heads/docs/*",
            "refs/heads/refactor/*",
            "refs/heads/chore/*"
          ],
          "exclude": []
        }
      },
      "rules": [
        {
          "type": "restrict_pushes",
          "parameters": {
            "restricts_pushes": true,
            "push_allowances": [
              {
                "type": "RepositoryRole",
                "repository_role_database_id": null
              }
            ]
          }
        }
      ]
    }
  ],
  "branch_protection_rules": {
    "main": {
      "enforce_admins": true,
      "required_status_checks": {
        "strict": false,
        "contexts": []
      },
      "required_pull_request_reviews": {
        "dismiss_stale_reviews": false,
        "require_code_owner_reviews": false,
        "required_approving_review_count": 1
      },
      "restrictions": {
        "users": [],
        "teams": []
      },
      "allow_force_pushes": false,
      "allow_deletions": false,
      "required_linear_history": false,
      "require_conversation_resolution": false
    }
  },
  "notes": {
    "setup_instructions": "See GITHUB_RULESETS_SETUP.md for import instructions",
    "owner": "@andresaugom",
    "created_date": "2026-03-21"
  }
}
